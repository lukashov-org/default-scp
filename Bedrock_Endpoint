{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "DenyBedrockAndMantleForSSOOutsidePrivateNetwork",
      "Effect": "Deny",
      "Action": [
        "bedrock:InvokeModel",
        "bedrock:InvokeModelWithResponseStream",
        "bedrock:Converse",
        "bedrock:ConverseStream",
        "bedrock:InvokeModelWithBidirectionalStream",
        "bedrock:StartAsyncInvoke",
        "bedrock:GetAsyncInvoke",
        "bedrock-mantle:*"
      ],
      "Resource": "*",
      "Condition": {
        "ArnLike": {
          "aws:PrincipalArn": "arn:aws:iam::*:role/aws-reserved/sso.amazonaws.com/AWSReservedSSO*"
        },
        "StringNotEquals": {
          "aws:SourceVpc": "vpc-0ff1ec04ea56681bd"
        },
        "NotIpAddress": {
          "aws:VpcSourceIp": "10.100.0.0/16"
        }
      }
    }
  ]
}
